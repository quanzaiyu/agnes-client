{
  "name": "@agnes/loader",
  "version": "1.0.0",
  "description": "Agnes AI Workflow Loader - run exported workflows from CLI or HTTP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agnes-flow": "bin/agnes-flow.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "tsx src/test.ts"
  },
  "dependencies": {
    "@agnes/core": "*",
    "@agnes/workflow": "*",
    "commander": "^12.1.0",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
