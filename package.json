{
  "name": "agnes-client",
  "version": "1.0.0",
  "description": "Agnes AI client with TUI, WebUI, Workflow and Loader",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:frontend\"",
    "dev:webui": "pnpm dev",
    "dev:tui": "node packages/tui/src/cli.js",
    "dev:flow": "node packages/workflow/server.cjs",
    "dev:server": "node packages/webui/src/server/index.js",
    "dev:frontend": "cd packages/webui/src/frontend && pnpm dev",
    "build": "cd packages/webui/src/frontend && pnpm build",
    "start": "node packages/webui/src/server/index.js",
    "setup": "pnpm install && cd packages/webui/src/frontend && pnpm install"
  },
  "dependencies": {
    "@agnes/core": "workspace:*",
    "@xyflow/react": "^12.4.0",
    "axios": "^1.7.2",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.3.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "form-data": "^4.0.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^12.0.0",
    "marked-terminal": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.9",
    "ora": "^8.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sql.js": "^1.10.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.4",
    "@iconify-json/ph": "^1.1.0",
    "@inquirer/prompts": "^5.3.8",
    "@sveltejs/adapter-node": "^5.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@types/node": "^22.10.0",
    "@unocss/svelte-scoped": "^0.60.0",
    "concurrently": "^8.2.2",
    "playwright": "^1.44.0",
    "svelte": "^4.2.0",
    "unocss": "^0.60.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "volta": {
    "node": "24.14.0",
    "pnpm": "10.33.4"
  }
}